---
layout: base.njk
title: Events — PoliTechs.uk
description: Join us at our next events — from panel discussions and workshops to hackathons and networking sessions.
---
{% from "event-card.njk" import eventCard %}

<main class="page-main">
  <div class="container">
    <h1 class="page-title">Events</h1>
    <p class="page-intro">
      Join us at our next events — from panel discussions and workshops to hackathons and networking sessions.
      All events welcome people from politics, technology, civil society, and beyond.
    </p>
    <div class="row g-4">
      {% for event in events %}
      <div class="col-md-6 col-lg-4">
        {{ eventCard(event) }}
      </div>
      {% endfor %}
    </div>
  </div>
</main>
