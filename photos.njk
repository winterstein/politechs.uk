---
layout: base.njk
title: Photos — National Conversations
---

<main>
  <section class="photos-section section-pad">
    <div class="container">
      <h1 class="page-title">Photos</h1>
      
      {% set currentEvent = null %}
      {% for photo in photos %}
        {% if photo.eventTitle != currentEvent or photo.year != currentYear or photo.location != currentLocation %}
          {% if currentEvent != null %}</div></div>{% endif %}
          {% set currentEvent = photo.eventTitle %}
          {% set currentYear = photo.year %}
          {% set currentLocation = photo.location %}
          <div class="gallery-group">
            <div class="gallery-header">
              <h2 class="gallery-title">{{ photo.eventTitle }}</h2>
              <p class="gallery-meta">{{ photo.year }} • {{ photo.location }}</p>
            </div>
            <div class="gallery-thumbnails">
        {% endif %}
              <a href="/photos/{{ photo.id }}/" class="photo-thumbnail-link">
                <div class="photo-thumbnail">
                  <img src="{{ photo.url }}" alt="{{ photo.eventTitle }} - {{ photo.location }}" class="photo-thumbnail-image" loading="lazy">
                </div>
              </a>
      {% endfor %}
      {% if currentEvent != null %}</div></div>{% endif %}
    </div>
  </section>
</main>

<style>
.gallery-group {
  margin-bottom: 3rem;
}

.gallery-header {
  margin-bottom: 1.5rem;
}

.gallery-title {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.gallery-meta {
  font-size: 0.875rem;
  color: #6c757d;
  margin: 0;
}

.gallery-thumbnails {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
}

.photo-thumbnail-link {
  text-decoration: none;
  display: block;
  transition: transform 0.2s ease;
}

.photo-thumbnail-link:hover {
  transform: scale(1.05);
}

.photo-thumbnail {
  overflow: hidden;
  border-radius: 0.5rem;
  aspect-ratio: 1;
  background-color: #f0f0f0;
}

.photo-thumbnail-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.photo-detail-container {
  display: flex;
  justify-content: center;
  margin: 2rem 0;
}

.photo-detail-figure {
  max-width: 800px;
  width: 100%;
}

.photo-detail-image {
  width: 100%;
  height: auto;
  border-radius: 0.5rem;
}

.photo-detail-title {
  margin-bottom: 0.5rem;
  font-size: 1.5rem;
}

.photo-detail-meta {
  font-size: 0.875rem;
}

.photo-nav {
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}
</style>
