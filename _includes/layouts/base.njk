<!doctype html>
<html lang="en">
  <head>
    {% set pageTitle = title or 'National Conversations — Politics meets Technology' %}
    {% set pageDescription = description or 'National Conversations — connecting politics and technology to improve society. Events, networking and debate on the key issues of our time.' %}
    {% set pageUrl = 'https://nationalconversations.org' ~ (page.url or '/') %}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ pageDescription }}" />
    <link rel="icon" type="image/png" sizes="360x360" href="/images/politechs.360x360.blue-white.png" />
    <link rel="apple-touch-icon" sizes="360x360" href="/images/politechs.360x360.blue-white.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ pageUrl }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:image" content="https://nationalconversations.org/images/nationalconversations_preview.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="{{ pageUrl }}" />
    <meta property="twitter:title" content="{{ pageTitle }}" />
    <meta property="twitter:description" content="{{ pageDescription }}" />
    <meta property="twitter:image" content="https://nationalconversations.org/images/nationalconversations_preview.png" />
    
    <title>{{ pageTitle }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="d-flex flex-column min-vh-100">
      {% include "header.njk" %}
      <div class="flex-grow-1">
        {{ content | safe }}
      </div>
      {% include "footer.njk" %}
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
