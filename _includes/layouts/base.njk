<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or 'PoliTechs.uk — connecting politics and technology to improve society. Events, networking and debate on the key issues of our time.' }}" />
    <title>{{ title or 'PoliTechs.uk — Politics meets Technology' }}</title>
    <link rel="icon" type="image/png" sizes="360x360" href="/images/politechs.360x360.trans-blue.png" />
    <link rel="apple-touch-icon" sizes="360x360" href="/images/politechs.360x360.trans-blue.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="d-flex flex-column min-vh-100">
      {% include "header.njk" %}
      <div class="flex-grow-1">
        {{ content | safe }}
      </div>
      {% include "footer.njk" %}
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmb7nZ30OwA+NI9b+4GiMnmm8L+M" crossorigin="anonymous"></script>
  </body>
</html>
