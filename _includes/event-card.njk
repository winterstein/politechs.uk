{% macro eventCard(event) %}
<div class="card event-card h-100">
  <div class="card-body d-flex flex-column">
    <div class="event-date-badge mb-2">
      {% set isTbcDate = event.date and (event.date | lower) == 'tbc' %}
      <span class="badge rounded-pill bg-primary">
        {% if isTbcDate %}
        {{ event.date }}
        {% else %}
        {{ event.date | formatDate }}
        {% endif %}
        {% if event.time %} &middot; {{ event.time }}{% endif %}
      </span>
    </div>
    <h5 class="card-title">{{ event.title }}</h5>
    <p class="event-location text-muted small mb-2">
      <i class="bi bi-geo-alt-fill me-1"></i>{{ event.location }}
    </p>
    {% if event.organised_with %}
    <p class="event-organised-with text-muted small mb-2">
      <strong>Organised with:</strong> {{ event.organised_with }}
    </p>
    {% endif %}
    <p class="card-text flex-grow-1">{{ event.description }}</p>
    {% if event.rsvpUrl %}
    <a href="{{ event.rsvpUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary mt-auto align-self-start">
      Register &rarr;
    </a>
    {% endif %}
  </div>
</div>
{% endmacro %}
