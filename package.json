{
  "name": "politechs.uk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:css": "sass src/styles/main.scss css/main.css --load-path=node_modules",
    "build": "npm run build:css && eleventy",
    "start": "npm run build:css && eleventy --serve",
    "watch:css": "sass --watch src/styles/main.scss css/main.css --load-path=node_modules",
    "dev": "concurrently \"npm run watch:css\" \"eleventy --serve\""
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "concurrently": "^9.1.2"
  }
}

